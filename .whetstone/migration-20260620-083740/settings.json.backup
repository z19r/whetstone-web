      "Bash(python:*)",
      "Bash(py:*)",
      "Bash(npx:*)",
      "mcp__memory__store_memory",
      "mcp__memory__recall_memory",
      "mcp__memory__associate_memories",
      "mcp__memory__update_memory",
      "mcp__memory__delete_memory",
      "mcp__memory__check_database_health"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(rm -rf /*)",
      "Bash(format:*)",
      "Bash(fdisk:*)"
    ],
    "ask": [
      "Bash(git push:*)"
    ],
    "defaultMode": "auto"
  },
